      <aliases enabled='yes' />
      <column caption='Cancelled Quantity' datatype='integer' name='[Calculation_100486632675151874]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [is_cancellation] = TRUE THEN ABS([quantity]) ELSE 0 END' />
      </column>
      <column caption='Valid Sales Revenue' datatype='real' default-format='c&quot;£ &quot;#,##0' name='[Calculation_100486632676245507]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [is_cancellation] = FALSE THEN [gross_revenue] ELSE 0 END' />
      </column>
      <column caption='Cancelled Revenue' datatype='real' default-format='c&quot;£ &quot;#,##0' name='[Calculation_100486632676429828]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [is_cancellation] = TRUE THEN ABS([gross_revenue]) ELSE 0 END' />
      </column>
      <column caption='Valid Sale Flag' datatype='integer' name='[Calculation_613615515167813633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [quantity] &gt; 0 AND [is_cancellation] = FALSE THEN 1 ELSE 0 END' />
      </column>
      <column caption='Cancellation Flag' datatype='integer' name='[Calculation_613615515167854594]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [is_cancellation] = TRUE THEN 1 ELSE 0 END' />
      </column>
      <column caption='Average Invoice Value' datatype='real' default-format='n&quot;£ &quot;#,##0;-&quot;£ &quot;#,##0' name='[Calculation_613615515167911939]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([gross_revenue]) / COUNTD([invoice_no])' />
      </column>
      <column caption='Revenue per Customer' datatype='real' name='[Calculation_613615515167956996]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([gross_revenue]) / COUNTD([customer_id])' />
      </column>
      <column caption='Cancellation Rate' datatype='real' default-format='p0.00%' name='[Calculation_613615515168014341]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_613615515167854594]) / COUNT([invoice_no])' />
      </column>
      <column caption='RFM Segment Sort' datatype='integer' name='[Calculation_613615515169017864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [customer_segment]&#13;&#10;WHEN &quot;Champions&quot; THEN 1&#13;&#10;WHEN &quot;Loyal Customers&quot; THEN 2&#13;&#10;WHEN &quot;New Customers&quot; THEN 3&#13;&#10;WHEN &quot;Needs Attention&quot; THEN 4&#13;&#10;WHEN &quot;At Risk&quot; THEN 5&#13;&#10;WHEN &quot;Hibernating&quot; THEN 6&#13;&#10;ELSE 7&#13;&#10;END' />
