              <flipboard active-id='2' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Revenue performance increased strongly toward late 2011, with top products and international markets driving overall sales.' captured-sheet='Executive Revenue Overview' id='1' />
                  <story-point caption='Champions generate the highest revenue, while at-risk high-value customers should be prioritized for reactivation.' captured-sheet='Customer Segmentation' id='2' />
                  <story-point caption='Cancellations are a small share of total revenue, but product and country patterns show where operational review is needed.' captured-sheet='Returns &amp; Cancellation Impact' id='3' />
                  <story-point caption='Final recommendations focus on customer retention, reactivation, product cancellation monitoring, and market-level review.' captured-sheet='' id='4' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
